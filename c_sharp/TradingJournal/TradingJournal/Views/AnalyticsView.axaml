<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TradingJournal.ViewModels"
             xmlns:converters="using:TradingJournal.Converters"
             x:Class="TradingJournal.Views.AnalyticsView"
             x:DataType="vm:AnalyticsViewModel">

    <UserControl.Resources>
        <converters:DateOnlyConverter x:Key="DateOnlyConverter"/>
        <converters:SignBrushConverter x:Key="SignBrushConverter"/>
    </UserControl.Resources>

    <ScrollViewer>
        <StackPanel Spacing="16" Margin="12">

            <!-- ── Filters ── -->
            <StackPanel Spacing="8">

                <!-- Date range toggles + ticker search -->
                <WrapPanel>

                    <!-- Segmented date-range selector -->
                    <StackPanel Orientation="Horizontal" Spacing="2" Margin="0,0,20,0">
                        <ToggleButton Content="All Time"
                                      IsChecked="{Binding IsAllTimeSelected, Mode=OneWay}"
                                      Command="{Binding SetRangeAllTimeCommand}"/>
                        <ToggleButton Content="This Month"
                                      IsChecked="{Binding IsThisMonthSelected, Mode=OneWay}"
                                      Command="{Binding SetRangeThisMonthCommand}"/>
                        <ToggleButton Content="This Year"
                                      IsChecked="{Binding IsThisYearSelected, Mode=OneWay}"
                                      Command="{Binding SetRangeThisYearCommand}"/>
                        <ToggleButton Content="Custom"
                                      IsChecked="{Binding IsCustomSelected, Mode=OneWay}"
                                      Command="{Binding SetRangeCustomCommand}"/>
                    </StackPanel>

                    <!-- Ticker filter -->
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <TextBlock Text="Ticker:"
                                   VerticalAlignment="Center"
                                   Opacity="0.7"/>
                        <TextBox Width="150"
                                 Text="{Binding FilterTicker}"
                                 PlaceholderText="Filter by ticker..."/>
                    </StackPanel>

                </WrapPanel>

                <!-- Custom date pickers — only visible when Custom range is selected -->
                <StackPanel Orientation="Horizontal"
                            Spacing="10"
                            IsVisible="{Binding IsCustomRange}">
                    <TextBlock Text="From:"
                               VerticalAlignment="Center"
                               Opacity="0.7"/>
                    <CalendarDatePicker SelectedDate="{ReflectionBinding CustomStart, Converter={StaticResource DateOnlyConverter}}"
                                        SelectedDateChanged="OnCustomStartChanged"
                                        PlaceholderText="Start date"/>
                    <TextBlock Text="To:"
                               VerticalAlignment="Center"
                               Opacity="0.7"/>
                    <CalendarDatePicker SelectedDate="{ReflectionBinding CustomEnd, Converter={StaticResource DateOnlyConverter}}"
                                        SelectedDateChanged="OnCustomEndChanged"
                                        PlaceholderText="End date"/>
                </StackPanel>

            </StackPanel>

            <!-- ── Summary Stats Row ── -->
            <StackPanel Orientation="Horizontal" Spacing="12">

                <!-- Total P/L -->
                <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="20,14"
                        MinWidth="180">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Total P/L"
                                   FontSize="12"
                                   Opacity="0.6"/>
                        <TextBlock Text="{Binding TotalPLFormatted}"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="{Binding TotalPL, Converter={StaticResource SignBrushConverter}}"/>
                    </StackPanel>
                </Border>

                <!-- Total G/L -->
                <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="20,14"
                        MinWidth="180">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Total G/L"
                                   FontSize="12"
                                   Opacity="0.6"/>
                        <TextBlock Text="{Binding TotalGLFormatted}"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="{Binding TotalGL, Converter={StaticResource SignBrushConverter}}"/>
                    </StackPanel>
                </Border>

                <!-- Total Trades -->
                <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="20,14"
                        MinWidth="140">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Total Trades"
                                   FontSize="12"
                                   Opacity="0.6"/>
                        <TextBlock Text="{Binding TotalTradesFormatted}"
                                   FontSize="22"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

            </StackPanel>

            <!-- ── Charts placeholder (Step 7) ── -->
            <TextBlock Text="Charts — coming in Step 7"
                       HorizontalAlignment="Center"
                       Margin="0,40"
                       FontSize="14"
                       Opacity="0.35"/>

        </StackPanel>
    </ScrollViewer>

</UserControl>
