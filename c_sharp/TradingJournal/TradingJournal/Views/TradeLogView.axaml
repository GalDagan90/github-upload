<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TradingJournal.ViewModels"
             xmlns:models="using:TradingJournal.Models"
             xmlns:converters="using:TradingJournal.Converters"
             x:Class="TradingJournal.Views.TradeLogView"
             x:DataType="vm:TradeLogViewModel">

    <UserControl.Resources>
        <converters:DateOnlyConverter x:Key="DateOnlyConverter"/>
        <converters:DateOnlyStringConverter x:Key="DateOnlyStringConverter"/>
        <converters:TradeStatusBrushConverter x:Key="TradeStatusBrushConverter"/>
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,*">

        <!-- Toolbar -->
        <Grid Grid.Row="0"
              Margin="8,8,8,4"
              ColumnDefinitions="Auto,*,Auto">

            <Button Grid.Column="0"
                    Content="+ Add Trade"
                    Command="{Binding AddTradeCommand}"
                    VerticalAlignment="Center"/>

            <!-- Filters -->
            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        Spacing="8"
                        VerticalAlignment="Center">

                <!-- Ticker search -->
                <TextBox Width="150"
                         Text="{Binding FilterTicker}"
                         PlaceholderText="Ticker..."
                         VerticalAlignment="Center"/>

                <!-- Strategy multi-select -->
                <Button Content="{Binding StrategyFilterLabel}">
                    <Button.Flyout>
                        <Flyout Placement="BottomEdgeAlignedLeft">
                            <StackPanel Spacing="4">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <Button Content="All"
                                            Command="{Binding SelectAllStrategyFiltersCommand}"
                                            HorizontalAlignment="Stretch"/>
                                    <Button Content="Clear"
                                            Command="{Binding ClearStrategyFiltersCommand}"
                                            HorizontalAlignment="Stretch"/>
                                </StackPanel>
                                <ScrollViewer MaxHeight="260">
                                    <ItemsControl ItemsSource="{Binding StrategyFilters}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{ReflectionBinding IsSelected}"
                                                          Content="{ReflectionBinding Label}"
                                                          Margin="4,2"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </StackPanel>
                        </Flyout>
                    </Button.Flyout>
                </Button>

                <!-- Status multi-select -->
                <Button Content="{Binding StatusFilterLabel}">
                    <Button.Flyout>
                        <Flyout Placement="BottomEdgeAlignedLeft">
                            <StackPanel Spacing="4">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <Button Content="All"
                                            Command="{Binding SelectAllStatusFiltersCommand}"
                                            HorizontalAlignment="Stretch"/>
                                    <Button Content="Clear"
                                            Command="{Binding ClearStatusFiltersCommand}"
                                            HorizontalAlignment="Stretch"/>
                                </StackPanel>
                                <ItemsControl ItemsSource="{Binding StatusFilters}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{ReflectionBinding IsSelected}"
                                                      Content="{ReflectionBinding Label}"
                                                      Margin="4,2"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Flyout>
                    </Button.Flyout>
                </Button>

            </StackPanel>
        </Grid>

        <!-- Trade DataGrid -->
        <DataGrid Grid.Row="1"
                  x:Name="TradesGrid"
                  ItemsSource="{Binding FilteredTrades}"
                  SelectedItem="{Binding SelectedTrade}"
                  RowEditEnded="OnRowEditEnded"
                  LoadingRow="OnLoadingRow"
                  PointerPressed="OnDataGridPointerPressed"
                  AutoGenerateColumns="False"
                  CanUserSortColumns="True"
                  GridLinesVisibility="All"
                  IsReadOnly="False"
                  Margin="8,0,8,8">

            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Delete Trade"
                              Command="{ReflectionBinding DeleteTradeCommand}"
                              CommandParameter="{ReflectionBinding SelectedTrade}"/>
                </ContextMenu>
            </DataGrid.ContextMenu>

            <DataGrid.Columns>

                <!-- Ticker -->
                <DataGridTextColumn Header="Ticker"
                                    Binding="{ReflectionBinding Ticker}"
                                    Width="Auto"/>

                <!-- Strike -->
                <DataGridTextColumn Header="Strike"
                                    Binding="{ReflectionBinding Strike}"
                                    Width="Auto"/>

                <!-- Strategy -->
                <DataGridTemplateColumn Header="Strategy" Width="Auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="models:Trade">
                            <ComboBox SelectedItem="{Binding StrategyType}"
                                      ItemsSource="{x:Static models:TradeLookups.StrategyTypes}"
                                      SelectionChanged="OnEnumComboChanged"
                                      HorizontalAlignment="Stretch"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Open Date -->
                <DataGridTemplateColumn Header="Open Date" Width="Auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="models:Trade">
                            <CalendarDatePicker SelectedDate="{Binding OpenDate, Converter={StaticResource DateOnlyConverter}}"
                                                SelectedDateChanged="OnDatePickerChanged"
                                                PlaceholderText="dd/mm/yyyy"
                                                HorizontalAlignment="Stretch"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Expiration Date -->
                <DataGridTemplateColumn Header="Exp Date" Width="Auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="models:Trade">
                            <CalendarDatePicker SelectedDate="{Binding ExpirationDate, Converter={StaticResource DateOnlyConverter}}"
                                                SelectedDateChanged="OnDatePickerChanged"
                                                PlaceholderText="dd/mm/yyyy"
                                                HorizontalAlignment="Stretch"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Close Date -->
                <DataGridTemplateColumn Header="Close Date" Width="Auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="models:Trade">
                            <CalendarDatePicker SelectedDate="{Binding CloseDate, Converter={StaticResource DateOnlyConverter}}"
                                                SelectedDateChanged="OnDatePickerChanged"
                                                PlaceholderText="dd/mm/yyyy"
                                                HorizontalAlignment="Stretch"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Days Open -->
                <DataGridTextColumn Header="Days Open"
                                    Binding="{ReflectionBinding DaysOpen}"
                                    IsReadOnly="True"
                                    Width="Auto"/>

                <!-- Days to Expiration -->
                <DataGridTextColumn Header="Days to Exp"
                                    Binding="{ReflectionBinding DaysToExpiration}"
                                    IsReadOnly="True"
                                    Width="Auto"/>

                <!-- Entry Price -->
                <DataGridTextColumn Header="Entry $"
                                    Binding="{ReflectionBinding EntryPrice}"
                                    Width="Auto"/>

                <!-- Closing Price -->
                <DataGridTextColumn Header="Closing $"
                                    Binding="{ReflectionBinding ClosingPrice}"
                                    Width="Auto"/>

                <!-- Quantity -->
                <DataGridTextColumn Header="Qty"
                                    Binding="{ReflectionBinding Quantity}"
                                    Width="Auto"/>

                <!-- P/L -->
                <DataGridTextColumn Header="P/L ($)"
                                    Binding="{ReflectionBinding PL}"
                                    IsReadOnly="True"
                                    Width="Auto"/>

                <!-- G/L -->
                <DataGridTextColumn Header="G/L ($)"
                                    Binding="{ReflectionBinding GL}"
                                    IsReadOnly="True"
                                    Width="Auto"/>

                <!-- Status -->
                <DataGridTemplateColumn Header="Status" Width="Auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="models:Trade">
                            <ComboBox SelectedItem="{Binding Status}"
                                      ItemsSource="{x:Static models:TradeLookups.TradeStatuses}"
                                      SelectionChanged="OnEnumComboChanged"
                                      Foreground="{Binding Status, Converter={StaticResource TradeStatusBrushConverter}}"
                                      HorizontalAlignment="Stretch"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Notes -->
                <DataGridTextColumn Header="Notes"
                                    Binding="{ReflectionBinding Notes}"
                                    Width="*"/>

            </DataGrid.Columns>
        </DataGrid>

    </Grid>

</UserControl>
