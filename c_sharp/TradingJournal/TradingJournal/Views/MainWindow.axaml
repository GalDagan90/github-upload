<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:TradingJournal.ViewModels"
        x:Class="TradingJournal.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Trading Journal"
        Width="1200" Height="700"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Browser-style tab: rounded top corners, background-based selection indicator -->
        <ControlTheme x:Key="{x:Type TabItem}" TargetType="TabItem">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
            <Setter Property="Opacity" Value="0.65"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Name="PART_LayoutRoot"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8,8,0,0"
                            Padding="{TemplateBinding Padding}"
                            Margin="2,6,2,0"
                            Cursor="Hand">
                        <ContentPresenter Name="PART_ContentPresenter"
                                          Content="{TemplateBinding Header}"
                                          ContentTemplate="{TemplateBinding HeaderTemplate}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter>

            <!-- Hover: subtle fill -->
            <Style Selector="^:pointerover">
                <Setter Property="Opacity" Value="0.85"/>
            </Style>
            <Style Selector="^:pointerover /template/ Border#PART_LayoutRoot">
                <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundListLowBrush}"/>
            </Style>

            <!-- Selected: full opacity, bold text, background matches content area -->
            <Style Selector="^:selected">
                <Setter Property="Opacity" Value="1"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
            </Style>
            <Style Selector="^:selected /template/ Border#PART_LayoutRoot">
                <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundAltHighBrush}"/>
            </Style>
            <Style Selector="^:selected:pointerover /template/ Border#PART_LayoutRoot">
                <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundAltHighBrush}"/>
            </Style>
        </ControlTheme>
    </Window.Resources>

    <!--
        Single Grid cell: TabControl fills the whole window.
        The theme toggle button is overlaid in the top-right corner of the same cell,
        floating over the tab strip row without needing a separate header bar.
    -->
    <Grid>
        <TabControl>
            <TabItem Header="Trade Log">
                <ContentControl Content="{Binding TradeLog}"/>
            </TabItem>
            <TabItem Header="Analytics">
                <ContentControl Content="{Binding Analytics}"/>
            </TabItem>
            <TabItem Header="Calendar">
                <ContentControl Content="{Binding Calendar}"/>
            </TabItem>
        </TabControl>

        <Button HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,10,16,0"
                Width="38" Height="38"
                FontSize="20"
                Command="{Binding ToggleThemeCommand}"
                Content="{Binding ThemeToggleIcon}"
                ToolTip.Tip="{Binding ThemeToggleTooltip}"/>
    </Grid>

</Window>
